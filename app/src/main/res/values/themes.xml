<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.EnetFiber" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="fontFamily">@font/dm_sans</item>
        <item name="colorPrimary">@color/color_enet</item>
        <item name="colorPrimaryVariant">@color/azul_oscuro</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/azul_secundario</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/color_enet</item>
        <item name="android:navigationBarColor">@color/color_enet</item>

    </style>

    <style name="Theme.EnetFiber.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <style name="BtnPrimario" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/color_enet</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingVertical" tools:ignore="NewApi">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="BtnSecundario" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/azul_secundario</item>
        <item name="android:textColor">@color/azul_secundario</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/azul_secundario</item>
        <item name="hintTextColor">@color/txt_hint</item>
        <item name="android:textColorHint">@color/txt_hint</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <style name="CardEstilo" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <!-- Agregar dentro de <resources> en themes.xml -->

    <style name="ToolbarTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#1E293B</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="NavItemTextStyle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:letterSpacing">0.0</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- También actualizar android:statusBarColor en Theme.EnetFiber -->
    <!-- <item name="android:statusBarColor">#FFFFFF</item> -->
    <!-- <item name="android:windowLightStatusBar">true</item>  (API 23+) -->

    <style name="TabTextStyle" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textAllCaps">false</item>
    </style>



    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>