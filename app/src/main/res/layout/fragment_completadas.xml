<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Header ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Órdenes completadas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:letterSpacing="-0.02"/>

            <TextView
                android:id="@+id/tvContador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="cargando..."
                android:textSize="13sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"/>

            <!-- Buscador -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_bg"
                android:layout_marginTop="12dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="@null"
                    app:tint="#94A3B8"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etBuscar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Buscar por cliente, contrato, dirección u orden"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:textSize="12sp"
                    tools:ignore="TouchTargetSizeCheck"/>
            </LinearLayout>

            <!-- Filtro fechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginEnd="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="@null"
                        app:tint="#94A3B8"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvFechaDesde"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Desde"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/input_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginStart="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="@null"
                        app:tint="#94A3B8"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvFechaHasta"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hasta"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Botón limpiar fechas -->
                <TextView
                    android:id="@+id/btnLimpiarFechas"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textSize="14sp"
                    android:textColor="#94A3B8"
                    android:paddingStart="10dp"
                    android:paddingEnd="4dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Chips de filtro -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="10dp">

                <RadioGroup
                    android:id="@+id/rgFiltroTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/chipTodos"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Todos"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="12sp"
                        tools:ignore="TouchTargetSizeCheck"/>

                    <RadioButton
                        android:id="@+id/chipInternet"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="📡 Internet"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="12sp"
                        tools:ignore="TouchTargetSizeCheck"/>

                    <RadioButton
                        android:id="@+id/chipCable"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="📺 Cable"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="12sp"
                        tools:ignore="TouchTargetSizeCheck"/>

                    <RadioButton
                        android:id="@+id/chipDuo"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="📡📺 Dúo"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="12sp"
                        tools:ignore="TouchTargetSizeCheck"/>

                </RadioGroup>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- ── Lista ───────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"/>

            <LinearLayout
                android:id="@+id/layoutVacio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin completadas aún"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#475569"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Las instalaciones completadas aparecerán aquí"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>