<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Toolbar azul — se une visualmente al hero -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E3A8A"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"/>

    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="#3B9FD4"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Hero azul sin bordes — continúa el toolbar ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E3A8A"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="36dp">

                <!-- Tipo + Estado -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:id="@+id/tvTipo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:textColor="#1E3A8A"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_tipo"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:layout_marginEnd="8dp"
                        tools:text="Instalación Internet"/>
                </LinearLayout>

                <!-- Nombre abonado -->
                <TextView
                    android:id="@+id/tvAbonado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.25"
                    tools:text="VARAS ZAVALETA,&#10;LUIS FERNANDO"/>

            </LinearLayout>

            <!-- ── Cards — margen negativo para solapar el hero ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="0dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="-16dp">

                <!-- Card datos del cliente -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DATOS DEL CLIENTE"
                            android:textSize="10sp"
                            android:textColor="#CBD5E1"
                            android:textStyle="bold"
                            android:letterSpacing="0.07"
                            android:layout_marginBottom="8dp"/>

                        <!-- DNI -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="9dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DNI" android:textSize="12sp" android:textColor="#94A3B8"/>
                            <TextView android:id="@+id/tvDni" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#0F172A" android:textStyle="bold" android:fontFamily="monospace" tools:text="73421890"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F8FAFC"/>

                        <!-- Contrato -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="9dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Contrato" android:textSize="12sp" android:textColor="#94A3B8"/>
                            <TextView android:id="@+id/tvContrato" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#0F172A" android:textStyle="bold" android:fontFamily="monospace" tools:text="C00000009821"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F8FAFC"/>

                        <!-- Dirección -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="top" android:paddingVertical="9dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dirección" android:textSize="12sp" android:textColor="#94A3B8"/>
                            <TextView android:id="@+id/tvDireccion" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:textSize="12sp" android:textColor="#0F172A" android:textStyle="bold" android:gravity="end" android:maxLines="2" tools:text="SEC. BARRIO 07 MZ. Y LT. 12"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F8FAFC"/>

                        <!-- Sector -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="9dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sector" android:textSize="12sp" android:textColor="#94A3B8"/>
                            <TextView android:id="@+id/tvSector" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#0F172A" android:textStyle="bold" tools:text="ZONA 11"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F8FAFC"/>

                        <!-- Referencia -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="top" android:paddingVertical="9dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Referencia" android:textSize="12sp" android:textColor="#94A3B8"/>
                            <TextView android:id="@+id/tvReferencia" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:textSize="12sp" android:textColor="#64748B" android:gravity="end" android:maxLines="2" tools:text="Frente al mercado central"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card observación -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardObservacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFBEB"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FDE68A"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="top">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_warning" app:tint="#92400E" android:layout_marginEnd="10dp" android:layout_marginTop="2dp" android:contentDescription="@null"/>
                        <TextView android:id="@+id/tvObservacion" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#92400E" android:lineSpacingExtra="3dp" tools:text="Cliente solicita llegar después de las 2pm."/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card WAN -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingTop="14dp" android:paddingBottom="14dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_network" android:layout_marginEnd="8dp" app:tint="#2563EB" android:contentDescription="@null"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WAN CONFIGURADA POR NOC" android:textSize="11sp" android:textColor="#2563EB" android:textStyle="bold" android:letterSpacing="0.06"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F1F5F9" android:padding="12dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="IP WAN" android:textSize="11sp" android:textColor="#94A3B8" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvIpWan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1E3A8A" android:fontFamily="monospace" android:textStyle="bold" tools:text="200.1.2.10"/>
                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E2E8F0" android:layout_marginVertical="4dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Máscara" android:textSize="11sp" android:textColor="#94A3B8" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvMascara" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#334155" android:fontFamily="monospace" tools:text="255.255.255.0"/>
                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E2E8F0" android:layout_marginVertical="4dp"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Gateway" android:textSize="11sp" android:textColor="#94A3B8" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvGateway" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#334155" android:fontFamily="monospace" tools:text="200.1.2.1"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card contacto -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingTop="14dp" android:paddingBottom="12dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONTACTO" android:textSize="10sp" android:textColor="#CBD5E1" android:textStyle="bold" android:letterSpacing="0.07" android:layout_marginBottom="12dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                                <!-- Llamar -->
                                <LinearLayout
                                    android:id="@+id/btnLlamar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:background="@drawable/bg_btn_llamar"
                                    android:padding="14dp"
                                    android:layout_marginEnd="6dp"
                                    android:clickable="true"
                                    android:focusable="true">
                                    <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/bg_icon_blue" android:gravity="center" android:layout_marginBottom="7dp">
                                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_phone" app:tint="#1D4ED8" android:contentDescription="@null"/>
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Llamar" android:textSize="12sp" android:textColor="#1D4ED8" android:textStyle="bold"/>
                                </LinearLayout>

                                <!-- WhatsApp -->
                                <LinearLayout
                                    android:id="@+id/btnWhatsapp"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:background="@drawable/bg_btn_whatsapp"
                                    android:padding="14dp"
                                    android:layout_marginStart="6dp"
                                    android:clickable="true"
                                    android:focusable="true">
                                    <LinearLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/bg_icon_green" android:gravity="center" android:layout_marginBottom="7dp">
                                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_whatsapp" app:tint="#166534" android:contentDescription="@null"/>
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WhatsApp" android:textSize="12sp" android:textColor="#166534" android:textStyle="bold"/>
                                </LinearLayout>

                            </LinearLayout>
                        </LinearLayout>

                        <!-- Ver en mapa -->
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F1F5F9"/>
                        <LinearLayout
                            android:id="@+id/btnMapa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="13dp"
                            android:clickable="true"
                            android:focusable="true">
                            <LinearLayout android:layout_width="30dp" android:layout_height="30dp" android:background="@drawable/bg_btn_mapa" android:gravity="center" android:layout_marginEnd="12dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_map_pin" app:tint="#64748B" android:contentDescription="@null"/>
                            </LinearLayout>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ver en mapa" android:textSize="13sp" android:textColor="#475569" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#CBD5E1"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- tvCelular oculto — usado por el Activity para llamar/WA -->
                <TextView
                    android:id="@+id/tvCelular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ── Botones fijos abajo ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:elevation="8dp">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:background="#E2E8F0"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAceptar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Aceptar orden"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#1E3A8A"
            app:cornerRadius="14dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Iniciar instalación"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#1E3A8A"
            app:cornerRadius="14dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>