<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- Toolbar con gradiente -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E3A8A"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"/>

    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="#3B9FD4"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="8dp">

            <!-- Hero card: abonado + tipo -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E3A8A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Badge tipo -->
                    <TextView
                        android:id="@+id/tvTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instalación Internet"
                        android:textSize="11sp"
                        android:textColor="#1E3A8A"
                        android:background="#FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:id="@+id/tvAbonado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvDni"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#93C5FD"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textSize="12sp"
                            android:textColor="#93C5FD"/>

                        <TextView
                            android:id="@+id/tvContrato"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#93C5FD"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tvDireccion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#DBEAFE"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#93C5FD"
                        android:layout_marginTop="3dp"
                        android:layout_marginStart="20dp"/>

                    <TextView
                        android:id="@+id/tvReferencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#93C5FD"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="20dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card observación -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardObservacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFBEB"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#FCD34D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="18sp"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:id="@+id/tvObservacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#92640A"
                        android:lineSpacingExtra="2dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card WAN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardWan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#86EFAC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textSize="14sp"
                            android:textColor="#16A34A"
                            android:textStyle="bold"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WAN CONFIGURADA POR NOC"
                            android:textSize="11sp"
                            android:textColor="#16A34A"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#DCFCE7"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvIpWan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#14532D"
                            android:fontFamily="monospace"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvMascara"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#166534"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvGateway"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#166534"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card contacto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#E2ECF4"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTACTO"
                        android:textSize="10sp"
                        android:textColor="#8AAABB"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📞"
                            android:textSize="16sp"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:id="@+id/tvCelular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#0D1B2A"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLlamar"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="Llamar"
                            android:textColor="#1E3A8A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="#EEF4FF"
                            app:cornerRadius="10dp"
                            app:strokeColor="#C8DAEA"
                            app:strokeWidth="1dp"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWhatsapp"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="WhatsApp"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:backgroundTint="#25D366"
                            app:cornerRadius="10dp"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMapa"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Ver en mapa"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        app:backgroundTint="#EEF4FF"
                        app:cornerRadius="10dp"
                        app:strokeColor="#C8DAEA"
                        app:strokeWidth="1dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botones fijos abajo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:elevation="12dp">

        <!-- Línea separadora -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#E2ECF4"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAceptar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✓  Aceptar orden"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:backgroundTint="#1E3A8A"
            app:cornerRadius="14dp"
            app:elevation="4dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continuar con la instalación  →"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#1E3A8A"
            app:cornerRadius="14dp"
            app:elevation="4dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>