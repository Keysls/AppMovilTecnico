<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Card: Avatar + nombre + stats inline -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Avatar + info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvIniciales"
                        android:layout_width="68dp"
                        android:layout_height="68dp"
                        android:gravity="center"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_avatar_azul"
                        android:text=""/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvNombre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Técnico"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/txt_primario"
                            android:letterSpacing="-0.01"/>

                        <TextView
                            android:id="@+id/tvZona"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sin zona asignada"
                            android:textSize="13sp"
                            android:textColor="@color/txt_secundario"
                            android:layout_marginTop="2dp"/>

                        <!-- Status pill -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_status_pill"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Activo"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/verde"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/divider"/>

                <!-- Stats inline -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOrdenesActivas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/txt_primario"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Órdenes activas"
                            android:textSize="11sp"
                            android:textColor="@color/txt_hint"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvOrdenesCompletadas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/txt_primario"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completadas"
                            android:textSize="11sp"
                            android:textColor="@color/txt_hint"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Contacto -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTACTO"
                    android:textSize="11sp"
                    android:textColor="@color/txt_hint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"/>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_square"
                        android:backgroundTint="@color/azul_secundario"
                        android:padding="7dp"
                        android:src="@drawable/ic_mail"
                        android:layout_marginEnd="12dp"/>

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Email"
                        android:textSize="14sp" android:textColor="@color/txt_primario"/>

                    <TextView android:id="@+id/tvEmail" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="60dp"/>

                <!-- Teléfono -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_square"
                        android:backgroundTint="@color/verde"
                        android:padding="7dp"
                        android:src="@drawable/ic_phone_perfil"
                        android:layout_marginEnd="12dp"/>

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Teléfono"
                        android:textSize="14sp" android:textColor="@color/txt_primario"/>

                    <TextView android:id="@+id/tvTelefono" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Datos laborales -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATOS LABORALES"
                    android:textSize="11sp"
                    android:textColor="@color/txt_hint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"/>

                <!-- DNI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_square"
                        android:backgroundTint="@color/morado"
                        android:padding="7dp"
                        android:src="@drawable/ic_badge"
                        android:layout_marginEnd="12dp"/>

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="DNI"
                        android:textSize="14sp" android:textColor="@color/txt_primario"/>

                    <TextView android:id="@+id/tvDni" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="60dp"/>

                <!-- Vehículo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_square"
                        android:backgroundTint="@color/naranja"
                        android:padding="7dp"
                        android:src="@drawable/ic_car"
                        android:layout_marginEnd="12dp"/>

                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Vehículo"
                        android:textSize="14sp" android:textColor="@color/txt_primario"/>

                    <TextView android:id="@+id/tvVehiculo" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Seguridad -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEGURIDAD"
                    android:textSize="11sp"
                    android:textColor="@color/txt_hint"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:paddingTop="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cambia tu contraseña periódicamente para mantener tu cuenta segura."
                        android:textSize="13sp"
                        android:textColor="@color/txt_secundario"
                        android:layout_marginBottom="14dp"
                        android:lineSpacingExtra="2dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCambiarPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Cambiar contraseña"
                        android:textSize="14sp"
                        android:textColor="@color/azul_primario"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:icon="@drawable/ic_lock"
                        app:iconTint="@color/azul_primario"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:backgroundTint="@color/azul_claro"
                        app:cornerRadius="14dp"
                        app:strokeWidth="0dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>