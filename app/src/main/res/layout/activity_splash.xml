<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:ignore="UselessParent">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="Logo Enet Fiber"
            android:src="@drawable/logo_enet"
            android:scaleType="fitCenter"
            tools:ignore="ImageContrastCheck"/>

        <TextView
            android:text="@string/enet_fiber_peru"
            android:textColor="#2151A1"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginBottom="8dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <TextView
            android:text="App Técnico Instalador"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <ProgressBar
            android:layout_width="200dp"
            android:layout_height="6dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:indeterminateTint="#2151A1"/>

        <TextView
            android:id="@+id/txt_splash_estado"
            android:text="Iniciando sistema..."
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

    </LinearLayout>

    <TextView
        android:text="Powered by Enet Fiber Perú"
        android:textSize="11sp"
        android:textColor="#2151A1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"/>

</RelativeLayout>