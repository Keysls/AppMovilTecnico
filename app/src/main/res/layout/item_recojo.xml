<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Ícono ♻ -->
    <TextView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="♻"
        android:textSize="16sp"
        android:background="@drawable/bg_metrica_azul"
        android:layout_marginEnd="12dp"/>

    <!-- Nombre + código PON -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRecojoNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0F172A"/>

        <TextView
            android:id="@+id/tvRecojoPon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#7C3AED"
            android:fontFamily="monospace"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvRecojoCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#94A3B8"/>
    </LinearLayout>

    <!-- Estado -->
    <TextView
        android:id="@+id/tvRecojoEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="pendiente"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#D97706"
        android:background="#FEF3C7"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"/>

</LinearLayout>