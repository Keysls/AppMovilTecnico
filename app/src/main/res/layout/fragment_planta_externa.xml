<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planta Externa"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/txt_primario"/>

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 trabajos"
                android:textSize="13sp"
                android:textColor="@color/txt_hint"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Spinner
                        android:id="@+id/spinnerTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"/>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- Lista -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTrabajos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="10dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- Empty state — flotante sobre la lista -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sin trabajos registrados.&#10;Toca + para crear uno."
        android:textSize="14sp"
        android:textColor="@color/txt_hint"
        android:gravity="center"
        android:layout_marginTop="180dp"
        android:visibility="gone"/>

    <!-- FAB flotante -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNuevo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:backgroundTint="@color/color_enet"
        android:contentDescription="Nuevo trabajo"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/white"/>
</FrameLayout>