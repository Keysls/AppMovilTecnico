<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#F1F5F9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Cuerpo ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="13dp"
            android:paddingBottom="10dp">

            <!-- Fila 1: N° · Tipo · WAN · Timer · Estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvNServicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="#4754"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#2563EB"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvTipo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Instalación Internet"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginStart="6dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvWanLista"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ WAN"
                    tools:visibility="visible"
                    android:textSize="10sp"
                    android:textColor="#16A34A"
                    android:textStyle="bold"
                    android:background="#F0FDF4"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#DC2626"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Para técnico"
                    tools:backgroundTint="#EFF6FF"
                    tools:textColor="#1D4ED8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- Nombre abonado -->
            <TextView
                android:id="@+id/tvAbonado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="VARAS ZAVALETA, LUIS FERNANDO"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="5dp"/>

            <!-- Dirección -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="SEC. BARRIO 07 MZ. Y LT. 12"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- Sector -->
            <TextView
                android:id="@+id/tvSector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="ZONA 11"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginStart="18dp"/>

        </LinearLayout>

        <!-- ── Sección expandible: materiales + config (solo COMPLETADA) ── -->
        <LinearLayout
            android:id="@+id/layoutExpandible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#F8FAFC"
            android:paddingHorizontal="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ProgressBar
                android:id="@+id/progressExpandible"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="8dp"
                android:visibility="gone"/>

            <!-- Materiales utilizados -->
            <TextView
                android:id="@+id/tvLabelMateriales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MATERIALES UTILIZADOS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:letterSpacing="0.04"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/layoutMateriales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvSinMateriales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin materiales registrados"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:visibility="gone"
                android:layout_marginBottom="10dp"/>

            <!-- Configuración WAN/ONU -->
            <TextView
                android:id="@+id/tvLabelConfig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURACIÓN WAN / ONU"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:letterSpacing="0.04"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/layoutConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

        <!-- ── Divider ─────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"/>

        <!-- ── Footer: Llamar + WhatsApp ──────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLlamar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="Llamar"
                android:textSize="13sp"
                android:textColor="#1D4ED8"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#EFF6FF"
                app:cornerRadius="10dp"
                app:strokeColor="#BFDBFE"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_phone"
                app:iconTint="#1D4ED8"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:iconPadding="5dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsapp"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="WhatsApp"
                android:textSize="13sp"
                android:textColor="#166534"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#F0FDF4"
                app:cornerRadius="10dp"
                app:strokeColor="#86EFAC"
                app:strokeWidth="1dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>