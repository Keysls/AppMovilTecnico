<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: N° + Tipo + WAN + Timer + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvNServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#4754"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/azul_primario"/>

            <TextView
                android:id="@+id/tvTipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Internet"
                android:textSize="11sp"
                android:textColor="@color/txt_hint"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/tvWanLista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ WAN"
                android:textSize="10sp"
                android:textColor="@color/verde"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"/>

        </LinearLayout>

        <!-- Nombre abonado -->
        <TextView
            android:id="@+id/tvAbonado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VARAS ZAVALETA LUIS FERNANDO"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/txt_primario"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Dirección -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SEC. BARRIO 07 MZ. Y LT. 12"
                android:textSize="12sp"
                android:textColor="@color/txt_secundario"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- Sector -->
        <TextView
            android:id="@+id/tvSector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZONA 11"
            android:textSize="11sp"
            android:textColor="@color/txt_hint"
            android:layout_marginTop="2dp"
            android:layout_marginStart="20dp"/>

        <!-- Celular + botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvCelular"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="955851150"
                android:textSize="13sp"
                android:textColor="@color/txt_secundario"
                android:layout_marginStart="5dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLlamar"
                style="@style/BtnSecundario"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Llamar"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsapp"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="WhatsApp"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp"
                app:backgroundTint="#25D366"
                app:cornerRadius="10dp"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>