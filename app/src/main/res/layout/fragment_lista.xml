<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ✅ Contenedor unificado de filtros -->
        <LinearLayout
            android:id="@+id/layoutFiltros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                app:queryHint="Buscar abonado..."
                app:iconifiedByDefault="false"
                app:searchIcon="@null"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="12dp"
                android:paddingBottom="8dp">

                <RadioGroup
                    android:id="@+id/radioGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/chipTodos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Todos"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="13sp"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/chipInternet"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Internet"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="13sp"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/chipCable"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Cable"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="13sp"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/chipDuo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Dúo"
                        android:textColor="@drawable/txt_chip_selector"
                        android:textSize="13sp"
                        tools:ignore="TouchTargetSizeCheck" />

                </RadioGroup>
            </HorizontalScrollView>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"/>

            <LinearLayout
                android:id="@+id/layoutVacio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvEmptyIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvEmptyTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/txt_secundario"/>

                <TextView
                    android:id="@+id/tvEmptySubtitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/txt_hint"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>