<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Spinner — altura wrap_content para que el texto no se corte -->
        <Spinner
            android:id="@+id/spinnerItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/input_bg"
            android:minHeight="44dp"/>

        <!-- Campo cantidad -->
        <EditText
            android:id="@+id/etCantidad"
            android:layout_width="70dp"
            android:layout_height="44dp"
            android:hint="Cant."
            android:importantForAutofill="no"
            android:textSize="14sp"
            android:textColor="#0F172A"
            android:textColorHint="#CBD5E1"
            android:gravity="center"
            android:inputType="number"
            android:singleLine="true"
            android:background="@drawable/input_bg"
            android:layout_marginEnd="6dp"/>

        <!-- Botón eliminar -->
        <ImageView
            android:id="@+id/btnEliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_trash"
            android:padding="8dp"
            android:background="@drawable/bg_btn_delete"
            android:contentDescription="Eliminar"
            app:tint="#EF4444"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Hint: unidad · máx X -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#94A3B8"
        android:paddingStart="2dp"
        android:layout_marginTop="3dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvReciclado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="♻ Reciclado"
        android:textSize="10sp"
        android:textColor="#065F46"
        android:background="@drawable/bg_badge_reciclado"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        android:layout_marginTop="2dp" />

</LinearLayout>