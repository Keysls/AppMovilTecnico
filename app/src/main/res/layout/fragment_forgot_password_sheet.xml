<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Indicador de arrastre -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#E3E9F2"
        android:backgroundTint="#CBD5E1"/>

    <!-- Ícono -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_lock"
        android:padding="14dp"
        android:background="@drawable/bg_icon_info"
        android:layout_marginBottom="16dp"/>

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Olvidaste tu contraseña?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0E2545"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="10dp"/>

    <!-- Mensaje principal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="El restablecimiento de contraseñas es gestionado por tu administrador. Comunícate con alguno de los siguientes contactos:"
        android:textSize="14sp"
        android:textColor="#6C7B91"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="20dp"/>

    <!-- Card: Administrador de sede -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="#F0F5FF"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#DBEAFE"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🏢"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Administrador de tu sede"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1E40AF"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicita el cambio directamente en tu sede"
                    android:textSize="12sp"
                    android:textColor="#6C7B91"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card: Personal NOC -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#F0FDF4"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#BBF7D0"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🖥️"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal del NOC"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#15803D"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contacta al equipo NOC para restablecer tu acceso"
                    android:textSize="12sp"
                    android:textColor="#6C7B91"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botón cerrar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCerrar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Entendido"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif"
        app:backgroundTint="#1F4E8C"
        app:cornerRadius="12dp"/>

</LinearLayout>