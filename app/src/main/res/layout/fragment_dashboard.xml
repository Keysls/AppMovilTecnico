<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Saludo -->
            <TextView
                android:id="@+id/tvBienvenido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola, Técnico"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/txt_primario"/>

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/txt_secundario"
                android:layout_marginTop="2dp"/>

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="6dp"
                android:indeterminateTint="@color/azul_primario"
                android:visibility="gone"/>

            <!-- Grid 2x2 de stats -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp">

                <!-- Internet -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📡 Internet" android:textSize="12sp" android:textColor="@color/txt_secundario"/>
                        <TextView android:id="@+id/tvPendientesInternet"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/azul_secundario" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                    <View android:layout_width="3dp" android:layout_height="match_parent"
                        android:layout_gravity="start" android:background="@color/azul_secundario"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cable -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📺 Cable" android:textSize="12sp" android:textColor="@color/txt_secundario"/>
                        <TextView android:id="@+id/tvPendientesCable"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/morado" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                    <View android:layout_width="3dp" android:layout_height="match_parent"
                        android:layout_gravity="start" android:background="@color/morado"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Dúo -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔀 Dúo" android:textSize="12sp" android:textColor="@color/txt_secundario"/>
                        <TextView android:id="@+id/tvPendientesDuo"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/naranja" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                    <View android:layout_width="3dp" android:layout_height="match_parent"
                        android:layout_gravity="start" android:background="@color/naranja"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Completadas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✅ Completadas" android:textSize="12sp" android:textColor="@color/txt_secundario"/>
                        <TextView android:id="@+id/tvCompletadas"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/verde" android:layout_marginTop="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="este mes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                    <View android:layout_width="3dp" android:layout_height="match_parent"
                        android:layout_gravity="start" android:background="@color/verde"/>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Accesos rápidos label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCESOS RÁPIDOS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/txt_hint"
                android:letterSpacing="0.06"
                android:layout_marginBottom="10dp"/>

            <!-- Card Internet -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInternet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="42dp" android:layout_height="42dp"
                        android:gravity="center" android:text="📡" android:textSize="20sp"
                        android:background="@color/azul_claro" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Internet" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubInternet" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Cable -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="42dp" android:layout_height="42dp"
                        android:gravity="center" android:text="📺" android:textSize="20sp"
                        android:background="@color/bg" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Cable" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubCable" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Dúo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDuo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="42dp" android:layout_height="42dp"
                        android:gravity="center" android:text="🔀" android:textSize="20sp"
                        android:background="@color/naranja_bg" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Dúo" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubDuo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Completadas -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCompletadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="42dp" android:layout_height="42dp"
                        android:gravity="center" android:text="✅" android:textSize="20sp"
                        android:background="@color/verde_bg" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completadas" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ver historial" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/azul_claro"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/azul_secundario"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡 Recuerda" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/azul_primario"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Al conectarte al equipo perderás internet. Los datos se guardan automáticamente."
                        android:textSize="11sp" android:textColor="@color/txt_secundario"
                        android:layout_marginTop="5dp" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hidden tvConexion para compatibilidad -->
            <TextView android:id="@+id/tvConexion" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>