<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Saludo -->
            <TextView
                android:id="@+id/tvBienvenido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola, Técnico"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/txt_primario"/>

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/txt_secundario"
                android:layout_marginTop="2dp"/>

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="6dp"
                android:indeterminateTint="@color/azul_primario"
                android:visibility="gone"/>

            <!-- Grid 2x2 de stats -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp">

                <!-- Internet -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="#E8EEFB"
                            android:padding="8dp"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/azul_secundario"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Internet" android:textSize="12sp" android:textColor="@color/txt_secundario"
                            android:layout_marginTop="10dp"/>
                        <TextView android:id="@+id/tvPendientesInternet"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/txt_primario" android:layout_marginTop="1dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cable -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="#F0E7FB"
                            android:padding="8dp"
                            android:src="@drawable/ic_tv"
                            app:tint="@color/morado"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cable" android:textSize="12sp" android:textColor="@color/txt_secundario"
                            android:layout_marginTop="10dp"/>
                        <TextView android:id="@+id/tvPendientesCable"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/txt_primario" android:layout_marginTop="1dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Dúo -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/naranja_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_shuffle"
                            app:tint="@color/naranja"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dúo" android:textSize="12sp" android:textColor="@color/txt_secundario"
                            android:layout_marginTop="10dp"/>
                        <TextView android:id="@+id/tvPendientesDuo"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/txt_primario" android:layout_marginTop="1dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pendientes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Completadas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="6dp"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/verde_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/verde"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completadas" android:textSize="12sp" android:textColor="@color/txt_secundario"
                            android:layout_marginTop="10dp"/>
                        <TextView android:id="@+id/tvCompletadas"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/txt_primario" android:layout_marginTop="1dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="este mes" android:textSize="10sp" android:textColor="@color/txt_hint"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Accesos rápidos label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCESOS RÁPIDOS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/txt_hint"
                android:letterSpacing="0.06"
                android:layout_marginBottom="10dp"/>

            <!-- Card Internet -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInternet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#E8EEFB"
                        android:padding="11dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/azul_secundario"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Internet" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubInternet" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Cable -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#F0E7FB"
                        android:padding="11dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_tv"
                        app:tint="@color/morado"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Cable" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubCable" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Dúo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDuo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/naranja_bg"
                        android:padding="11dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_shuffle"
                        app:tint="@color/naranja"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendientes Dúo" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:id="@+id/tvSubDuo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="— órdenes sin atender" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Completadas -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCompletadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="@color/verde_bg"
                        android:padding="11dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/verde"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completadas" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/txt_primario"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ver historial" android:textSize="12sp" android:textColor="@color/txt_hint" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/txt_hint"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/azul_claro"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/azul_secundario"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginTop="1dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="@color/azul_primario"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Recuerda" android:textSize="12sp" android:textStyle="bold"
                            android:textColor="@color/azul_primario"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Al conectarte al equipo perderás internet. Los datos se guardan automáticamente."
                            android:textSize="11sp" android:textColor="@color/txt_secundario"
                            android:layout_marginTop="5dp" android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hidden tvConexion para compatibilidad -->
            <TextView android:id="@+id/tvConexion" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>