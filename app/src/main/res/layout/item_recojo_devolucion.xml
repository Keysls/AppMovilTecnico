<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#F0FDF4"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#BBF7D0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Checkbox -->
        <CheckBox
            android:id="@+id/cbRecojoSeleccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:buttonTint="#16A34A"/>

        <!-- Info del recojo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRecojoNombreDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#166534"/>

            <TextView
                android:id="@+id/tvRecojoPonDev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#15803D"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Badge ♻ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♻"
            android:textSize="16sp"
            android:layout_marginStart="6dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>