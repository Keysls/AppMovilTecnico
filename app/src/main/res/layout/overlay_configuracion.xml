<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlay_configuracion"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0F1E"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="28dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/overlay_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="20dp">

            <!-- ══ HEADER AZUL ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#2151A1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/icon_logo_e"
                    android:scaleType="fitCenter"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENET FIBER PERU"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/ov_subtitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Configuración ONT"
                        android:textColor="#A8C4E8"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/ov_btn_cerrar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="#A8C4E8"
                    android:textSize="14sp"
                    android:background="@drawable/overlay_close_bg"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Línea acento -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#1E4C8A"/>

            <!-- ══ BODY ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- ════ WAN ════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="3dp" android:layout_height="13dp"
                        android:background="#2151A1" android:layout_marginEnd="7dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WAN · IP ESTÁTICA" android:textColor="#2151A1"
                        android:textSize="9sp" android:letterSpacing="0.15"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="5dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="IP WAN" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_wan_ip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#2151A1"
                            android:textSize="14sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GATEWAY" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_wan_gw"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#1A1A2E"
                            android:textSize="14sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="14dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MÁSCARA" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_wan_mask"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#1A1A2E"
                            android:textSize="12sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="DNS" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_dns"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#1A1A2E"
                            android:textSize="11sp" android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ════ WIFI ════ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="3dp" android:layout_height="13dp"
                        android:background="#2151A1" android:layout_marginEnd="7dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WIFI · CREDENCIALES" android:textColor="#2151A1"
                        android:textSize="9sp" android:letterSpacing="0.15"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Card 2.4 GHz -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="#F0F4FA"
                    android:layout_marginBottom="5dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="#2151A1" android:paddingStart="10dp"
                        android:paddingEnd="10dp" android:paddingTop="6dp" android:paddingBottom="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📶  2.4 GHz" android:textColor="#FFFFFF"
                            android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NOMBRE DE RED" android:textColor="#7A9DBB"
                                android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/ov_ssid_24"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#1E4C8A"
                                android:textSize="14sp" android:textStyle="bold"
                                android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#DCE6F5"/>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CONTRASEÑA" android:textColor="#7A9DBB"
                                android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/ov_wifi_pass"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#1A1A2E"
                                android:textSize="13sp" android:fontFamily="monospace"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Card 5 GHz -->
                <LinearLayout android:id="@+id/ov_ssid5_row"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="#F0F4FA"
                    android:layout_marginBottom="14dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="#1E4C8A" android:paddingStart="10dp"
                        android:paddingEnd="10dp" android:paddingTop="6dp" android:paddingBottom="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🚀  5 GHz" android:textColor="#FFFFFF"
                            android:textSize="10sp" android:textStyle="bold" android:fontFamily="monospace"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NOMBRE DE RED" android:textColor="#7A9DBB"
                                android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/ov_ssid_5g"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#1E4C8A"
                                android:textSize="14sp" android:textStyle="bold"
                                android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#DCE6F5"/>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CONTRASEÑA" android:textColor="#7A9DBB"
                                android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                            <TextView android:id="@+id/ov_wifi_pass_5g"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="—" android:textColor="#1A1A2E"
                                android:textSize="13sp" android:fontFamily="monospace"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ════ DISPOSITIVO ════ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="3dp" android:layout_height="13dp"
                        android:background="#2151A1" android:layout_marginEnd="7dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DISPOSITIVO" android:textColor="#2151A1"
                        android:textSize="9sp" android:letterSpacing="0.15"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/ov_sn_row"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#F0F4FA" android:orientation="vertical"
                    android:padding="10dp" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="GPON SN" android:textColor="#7A9DBB"
                        android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/ov_sn"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#2151A1"
                        android:textSize="14sp" android:textStyle="bold"
                        android:fontFamily="monospace" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- ════ SEÑAL ÓPTICA PON ════ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="3dp" android:layout_height="13dp"
                        android:background="#2151A1" android:layout_marginEnd="7dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SEÑAL ÓPTICA PON" android:textColor="#2151A1"
                        android:textSize="9sp" android:letterSpacing="0.15"
                        android:fontFamily="monospace" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <!-- RX -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="RX POWER" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_rx"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#1E7A3A"
                            android:textSize="16sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="7dp" android:background="#DCE6F5">
                            <View android:id="@+id/ov_rx_bar"
                                android:layout_width="0dp" android:layout_height="match_parent"
                                android:background="#27AE60"/>
                        </FrameLayout>
                        <TextView android:id="@+id/ov_rx_label"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="dBm" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <!-- TX -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="5dp"
                        android:background="#F0F4FA" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TX POWER" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/ov_tx"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textColor="#2151A1"
                            android:textSize="16sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="7dp" android:background="#DCE6F5">
                            <View android:id="@+id/ov_tx_bar"
                                android:layout_width="0dp" android:layout_height="match_parent"
                                android:background="#2151A1"/>
                        </FrameLayout>
                        <TextView android:id="@+id/ov_tx_label"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="dBm" android:textColor="#7A9DBB"
                            android:textSize="8sp" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Aviso PON no disponible -->
                <LinearLayout android:id="@+id/ov_pon_na_row"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="#EEF3FB" android:orientation="horizontal"
                    android:gravity="center_vertical" android:padding="10dp"
                    android:layout_marginBottom="8dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ℹ  " android:textColor="#7A9DBB" android:textSize="12sp"/>
                    <TextView android:id="@+id/ov_pon_na_txt"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Señal no disponible para este equipo"
                        android:textColor="#7A9DBB" android:textSize="10sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- ════ FOOTER ════ -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#DCE6F5" android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView android:layout_width="14dp" android:layout_height="14dp"
                        android:src="@drawable/icon_logo_e" android:scaleType="fitCenter" android:alpha="0.3"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  ENET FIBER PERU · Configuración generada automáticamente"
                        android:textColor="#C0CEDF" android:textSize="8sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ov_btn_nueva_config"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="COMPARTIR"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="6dp"
                    app:backgroundTint="@color/color_enet"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ov_btn_continuar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="✓  Aceptar y continuar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="6dp"
                    app:backgroundTint="#2151A1"
                    android:layout_marginTop="8dp"
                    tools:ignore="HardcodedText"/>

                <!-- ID fantasma para ov_titulo (requerido por bindViews) -->
                <TextView android:id="@+id/ov_titulo"
                    android:layout_width="0dp" android:layout_height="0dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>